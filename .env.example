# Production Environment Variables
# Copy this file to .env and fill in actual values

PORT=3000
NODE_ENV=production

# Database Configuration
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=SCHEMA_NAME
DATABASE_URL="postgresql://umunsi_user:YOUR_PASSWORD@localhost:5432/umunsi_db?schema=umunsi"

# JWT Configuration
# Generate a strong secret: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# Frontend URL for CORS
FRONTEND_URL=https://umunsi-chi.vercel.app

# File Upload Settings
UPLOAD_DIR=/home/umunsi/htdocs/umunsi.com/umunsi-backendOG/uploads
MAX_FILE_SIZE=50000000

# Email Configuration (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-specific-password
SMTP_FROM=noreply@umunsi.com

# Admin Email
ADMIN_EMAIL=admin@umunsi.com

# API Keys (if needed)
# API_KEY=your-api-key-here

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Logging
LOG_LEVEL=info
