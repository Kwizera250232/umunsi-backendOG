# Production Environment Variables
# Copy this file to .env and fill in actual values

PORT=3000
NODE_ENV=production

# Database Configuration
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=SCHEMA_NAME
DATABASE_URL="postgresql://umunsi_com_user:YOUR_PASSWORD@localhost:5432/umunsi_db?schema=umunsi"

# JWT Configuration
# Generate a strong secret: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# Frontend URL for CORS
FRONTEND_URL=https://umunsi-chi.vercel.app

# File Upload Settings
UPLOAD_DIR=/home/umunsi/htdocs/umunsi.com/umunsi-backendOG/uploads
MAX_FILE_SIZE=50000000

# Email Configuration (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-specific-password
SMTP_FROM=noreply@umunsi.com

# Milestone Email Controls
ENABLE_POST_VIEW_MILESTONE_EMAILS=true
POST_VIEW_MILESTONES=100,200,500,1000,2000,5000,10000
# auto | smtp | mailtrap
MILESTONE_MAIL_PROVIDER=smtp
# author_admin | all_users | selected
MILESTONE_RECIPIENT_MODE=author_admin
MILESTONE_INCLUDE_AUTHOR_AND_ADMINS=true
MILESTONE_SELECTED_RECIPIENTS=

# Admin Email
ADMIN_EMAIL=admin@umunsi.com

# API Keys (if needed)
# API_KEY=your-api-key-here

# KPay Payment Gateway (Sandbox/Live)
# Sandbox example: https://pay.esicia.com
# Live example: https://pay.esicia.rw
KPAY_BASE_URL=https://pay.esicia.com
KPAY_API_PATH=/
KPAY_USERNAME=
KPAY_PASSWORD=
KPAY_RETAILER_ID=
KPAY_DEFAULT_COUNTRY_CODE=250

# SMS Providers (optional, at least one recommended)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

AFRICASTALKING_USERNAME=
AFRICASTALKING_API_KEY=
AFRICASTALKING_SENDER_ID=

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Logging
LOG_LEVEL=info
