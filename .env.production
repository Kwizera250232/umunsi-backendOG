PORT=3000
NODE_ENV=production
DATABASE_URL="postgresql://umunsi_user:your_secure_password@localhost:5432/umunsi_db?schema=public"
JWT_SECRET=generate-a-very-long-random-secret-key-here-min-32-chars
JWT_EXPIRE=7d
API_URL=https://umunsi.com
FRONTEND_URL=https://umunsi-chi.vercel.app
